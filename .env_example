# Database Configuration

POSTGRES_USER=your_db_user_here
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=your_db_name_here
POSTGRES_HOST=db
POSTGRES_PORT=xxxx
POSTGRES_SSLMODE=disable

# Flask Configuration

FLASK_SECRET_KEY=your_secure_random_flask_secret_key_here

# Set to true ONLY for local development (exposes reset link in API response).
# Must be false or omitted in staging/production.
DEBUG=false

# HMAC key for signing token hashes stored in DB (separate from Flask session key)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
TOKEN_HMAC_KEY=your_secure_random_token_hmac_key_here

# Brute-force lockout policy
# Lock account after this many consecutive failures
MAX_FAILED_ATTEMPTS=5
# How long the auto-lockout lasts (in minutes)
LOCKOUT_DURATION_MINUTES=15
# Minimum response time for /forgot POST in seconds (prevents timing-based email enumeration)
FORGOT_MIN_RESPONSE_SECONDS=0.3
# Session expiry in minutes (how long a logged-in session stays valid)
SESSION_LIFETIME_MINUTES=30
